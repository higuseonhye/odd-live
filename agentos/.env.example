# Never commit real keys. Copy to `.env` locally (gitignored).
OPENAI_API_KEY=
# Set to true to always use deterministic stub steps (ignore OPENAI_API_KEY).
AGENTOS_FORCE_STUB=false
# Optional: override default gpt-4o-mini
# AGENTOS_OPENAI_MODEL=gpt-4o-mini
AGENTOS_ADMIN_PASSWORD=
AGENTOS_SECRET_KEY=
AGENTOS_ENV=development
AGENTOS_LOG_PAYLOADS=false
AGENTOS_LOG_LEVEL=INFO
AGENTOS_POLICY_PATH=policies/default.yaml
AGENTOS_API_HOST=0.0.0.0
AGENTOS_API_PORT=8080
FLASK_DEBUG=false
AGENTOS_CORS_ORIGINS=
REDIS_URL=redis://redis:6379/0
